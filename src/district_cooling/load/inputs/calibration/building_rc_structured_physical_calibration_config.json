      "C_indoor"
    ],
    "rc_prior_mean_weight": 0.0,
    "rc_prior_mean_parameters": [],
    "optimizer": "scipy_de_l_bfgs_b",
    "population_size": 10,
    "random_seed": 31,
    "max_iterations": 32,
    "polish": true,
    "force_level": 4,
    "dynamic_loss": {
      "temperature_rmse_weight": 1.0,
      "cooling_on_threshold_kw": 10.0,
      "cooling_on_slope_weight": 0.8,
      "cooling_off_slope_weight": 1.2
    }
  },
  "structured_parameters": {
