{
  "dataset_name": "wzs_building_structured_physical_parameter_identification",
  "mode": "structured",
  "measurement_run_config_path": "src/district_cooling/load/inputs/measurements/wzs_building_run_config.json",
  "output_dir": "run_cache/wzs_heuristic_initial_fitted_transfer/calibration",
  "building_type_prior": {
    "path": "src/district_cooling/load/inputs/building_type_rc_priors.json",
    "category": "office",
    "apply_as_hard_bounds": false
