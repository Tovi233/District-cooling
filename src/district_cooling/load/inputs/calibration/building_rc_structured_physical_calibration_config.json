      "initial": 2112000.0,
      "min": 1500000.0,
      "max": 2600000.0
    },
    "floor_slab_thickness_m": {
      "initial": 0.2,
      "min": 0.08,
      "max": 0.3
    },
    "floor_slab_lambda_w_per_m_k": {
      "initial": 1.4,
      "min": 0.8,
      "max": 2.0
    },
    "floor_slab_volumetric_heat_capacity_j_per_m3_k": {
      "initial": 2112000.0,
      "min": 1500000.0,
      "max": 2600000.0
    },
    "indoor_object_heat_capacity_per_floor_area_j_per_m2_k": {
      "initial": 500000.0,
      "min": 100000.0,
      "max": 1000000.0
    },
    "mass_exchange_h_w_per_m2_k": {
      "initial": 14.0,
